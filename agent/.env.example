# Supabase — write access (service/secret key, never commit)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Phase 2: Ollama (fill in when ready)
OLLAMA_API_KEY=
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2:3b

# Phase 4: OpenClaw (fill in when ready)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
USE_OPENCLAW=false

# Telegram bot (optional — enables /run, /logs commands and pipeline notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
VPS_CONTROL_TOKEN=run-newsroom-2026
